#!/usr/bin/env bash
# =============================================================================
# maestro — helper CLI for Maestro v2 (lead-agent orchestration)
# =============================================================================
# There is NO headless runner any more: workflows are driven by YOUR interactive
# session (Claude Code, Cursor, …) via the /maestro skill — zero API keys.
# This wrapper covers everything around that:
#
#   maestro init <slug>              scaffold .maestro/<slug>/requirement/
#   maestro validate [workflow]      lint a workflow file (default workflows/sdlc-main.yaml)
#   maestro status <slug>            show the run's step table / gates / cursors
#   maestro reset <slug> [...]       forward to maestroctl reset (e.g. --step X --cascade)
#   maestro ui                       open the visual workflow builder
#   maestro <slug> [workflow]        preflight a run, then tell you the /maestro command
#
# Requires python3 on PATH. Run from your repo root (where engine/ + workflows/ live).
# =============================================================================
set -uo pipefail

usage() { sed -n '3,17p' "$0" | sed 's/^# \{0,1\}//'; exit "${1:-0}"; }

die() { echo "maestro: $*" >&2; exit 1; }

repo_root() {
  # engine/maestroctl.py marks the root; walk up from cwd
  local d="$PWD"
  while [ "$d" != "/" ]; do
    [ -f "$d/engine/maestroctl.py" ] && { echo "$d"; return 0; }
    d="$(dirname "$d")"
  done
  die "engine/maestroctl.py not found — run from a repo where the Maestro pack is installed"
}

[ $# -ge 1 ] || usage 2
cmd="$1"; shift || true
case "$cmd" in
  -h|--help|help) usage 0 ;;
esac

ROOT="$(repo_root)"
CTL=(python3 "$ROOT/engine/maestroctl.py" --root "$ROOT")

case "$cmd" in
  init)
    [ $# -ge 1 ] || die "usage: maestro init <slug>"
    slug="$1"
    dir="$ROOT/.maestro/$slug/requirement"
    mkdir -p "$dir"
    if [ ! -e "$dir/requirement.md" ]; then
      cat > "$dir/requirement.md" <<'EOF'
# Requirement

Describe the feature here. Every file in this folder is read as the requirement:
drop in PRDs, ticket exports, API notes, screenshots-as-markdown — anything.
EOF
    fi
    echo "scaffolded $dir"
    echo "next: fill in the requirement, then run:  maestro $slug"
    ;;
  validate)
    wf="${1:-workflows/sdlc-main.yaml}"
    exec "${CTL[@]}" validate "$wf"
    ;;
  status)
    [ $# -ge 1 ] || die "usage: maestro status <slug>"
    exec "${CTL[@]}" status --slug "$1"
    ;;
  reset)
    [ $# -ge 1 ] || die "usage: maestro reset <slug> [--step X ... | --all] [--cascade]"
    slug="$1"; shift
    exec "${CTL[@]}" reset --slug "$slug" "$@"
    ;;
  ui)
    html="$ROOT/ui/builder.html"
    [ -f "$html" ] || die "ui/builder.html not found"
    case "$(uname -s)" in
      Darwin) open "$html" ;;
      Linux)  xdg-open "$html" >/dev/null 2>&1 || die "xdg-open failed — open $html manually" ;;
      *)      echo "open this file in a browser: $html" ;;
    esac
    ;;
  *)
    # maestro <slug> [workflow] — preflight, then hand off to the interactive session
    slug="$cmd"
    wf="${1:-workflows/sdlc-main.yaml}"
    [ -f "$ROOT/$wf" ] || die "workflow not found: $wf"
    "${CTL[@]}" validate "$wf" >/dev/null || die "workflow has validation errors — fix them first (maestro validate $wf)"
    req="$ROOT/.maestro/$slug/requirement"
    if [ ! -d "$req" ] || ! find "$req" -type f -size +1c 2>/dev/null | grep -q .; then
      echo "warning: no requirement files at .maestro/$slug/requirement/ — run: maestro init $slug" >&2
    fi
    if [ -f "$ROOT/.maestro/$slug/state.yaml" ]; then
      echo "existing run found — it will RESUME where it left off (maestro status $slug to inspect)."
    fi
    echo
    echo "Workflows run inside your interactive AI session (no API keys needed)."
    echo "Open your IDE (Claude Code, Cursor, …) in this repo and run:"
    echo
    if [ "$wf" = "workflows/sdlc-main.yaml" ]; then
      echo "    /maestro $slug"
    else
      echo "    /maestro $slug $wf"
    fi
    echo
    ;;
esac
